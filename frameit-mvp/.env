# Frameit MVP — local environment
# Copy this file from .env.example, then fill in your values.
# The app runs fine with everything left blank (Spotify features are skipped).

# ── Spotify (optional) ─────────────────────────────────────────────────────
# Get credentials at: https://developer.spotify.com/dashboard
# Leave blank to skip music recommendations.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# ── ML backend ──────────────────────────────────────────────────────────────
# "fallback"    → pure NumPy, no GPU needed, no extra installs (default)
# "open_clip"   → requires: pip install open-clip-torch
# "transformers" → requires: pip install transformers torch
CLIP_BACKEND=fallback

# ── Paths (defaults work for local dev, no need to change) ─────────────────
UPLOAD_DIR=uploads
OUTPUT_DIR=output
TEMPLATES_DIR=collage_templates
ASSETS_DIR=assets

# ── Pipeline limits ─────────────────────────────────────────────────────────
MAX_PHOTOS=10
MIN_PHOTOS=1
JPEG_QUALITY=95

# ── Server ──────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173